---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import memoryLessons from '../../data/memory-lessons.json';

type MemoryLesson = {
  lessonNumber: number;
  of: number;
  title: string;
  oneLiner: string;
  block: string;
  locus: string;
  encodedDate: string;
  encodedSession: string;
  rating: number;
  status: string;
  whyItWorks: string;
};

const sortedMemory = (memoryLessons as MemoryLesson[])
  .slice()
  .sort((a, b) => b.encodedDate.localeCompare(a.encodedDate));

const findings = (await getCollection('lessons', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const memoryTotal = sortedMemory.length;
const findingsTotal = findings.length;
---

<Layout title="Findings" description="Compounding artifacts from both pillars — memory lessons from Encode, business findings from Forge.">
  <header class="mb-10">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">// Compounding artifacts</p>
    <h1 class="text-4xl font-bold tracking-tight mb-3">Findings</h1>
    <p class="text-neutral-300 max-w-2xl leading-relaxed">
      The two streams that compound across sessions. Memory lessons get encoded into a palace and cold-tested on a spaced-rep schedule. Business findings distill one transferable principle from each Forge build, anchored in a real historical case. Both halves of the niche on one page.
    </p>
  </header>

  <section class="grid grid-cols-1 md:grid-cols-2 border border-neutral-800 -mx-6 md:mx-0">

    <!-- MEMORY LESSONS — white pane (Encode palette) -->
    <div class="bg-white text-black border-b md:border-b-0 md:border-r border-neutral-800">
      <div class="px-6 py-10">
        <div class="flex items-baseline justify-between mb-2">
          <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-neutral-500">// Pillar I — Encode</p>
          <p class="text-[10px] font-mono uppercase tracking-wider text-neutral-500">{memoryTotal} / 170</p>
        </div>
        <h2 class="text-3xl font-black tracking-tight mb-4">Memory Lessons</h2>
        <p class="text-sm text-neutral-700 mb-8 leading-relaxed">
          The 170-lesson curriculum, encoded one locus at a time. Each lesson is a permanent palace position with an EPIC image — Energize, Physics-breaking, Impossible scale, Charged emotion. Honest ★1-5 rating; the homepage doesn't lie.
        </p>

        {sortedMemory.length === 0 ? (
          <p class="text-neutral-500">No memory lessons encoded yet.</p>
        ) : (
          <ul class="space-y-5">
            {sortedMemory.map((lesson) => {
              const stars = '★'.repeat(lesson.rating) + '☆'.repeat(5 - lesson.rating);
              return (
                <li>
                  <a href={`/encode/memory/${lesson.lessonNumber}`} class="block group no-underline">
                    <article class="border-l-2 border-neutral-300 pl-4 py-1 group-hover:border-black transition-colors">
                      <div class="flex flex-wrap items-center gap-2 mb-1 text-[11px] font-mono text-neutral-500">
                        <span>Lesson {lesson.lessonNumber} / {lesson.of}</span>
                        <span>·</span>
                        <span>{lesson.encodedDate}</span>
                        <span>·</span>
                        <span>{lesson.encodedSession}</span>
                        <span>·</span>
                        <span>{stars}</span>
                      </div>
                      <h3 class="text-lg font-semibold tracking-tight mb-1 group-hover:underline">
                        {lesson.title}
                      </h3>
                      <p class="text-neutral-700 text-sm leading-relaxed">{lesson.oneLiner}</p>
                    </article>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </div>

    <!-- FORGE FINDINGS — dark pane (Forge palette) -->
    <div class="bg-black text-white">
      <div class="px-6 py-10">
        <div class="flex items-baseline justify-between mb-2">
          <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-neutral-400">// Pillar II — Forge</p>
          <p class="text-[10px] font-mono uppercase tracking-wider text-neutral-400">{findingsTotal} shipped</p>
        </div>
        <h2 class="text-3xl font-black tracking-tight mb-4">Forge Findings</h2>
        <p class="text-sm text-neutral-300 mb-8 leading-relaxed">
          Business lessons distilled from build sessions. Each Finding is one transferable principle — what a confident audit gets wrong, why a fix can break what was working, when the source beats the report — anchored in a real historical case (Theranos, Bill Campbell, Three Mile Island, and others as the program runs).
        </p>

        {findings.length === 0 ? (
          <p class="text-neutral-500">No findings yet.</p>
        ) : (
          <ul class="space-y-5">
            {findings.map((lesson) => {
              const dateLabel = lesson.data.date.toISOString().slice(0, 10);
              return (
                <li>
                  <a href={`/lessons/${lesson.slug}`} class="block group no-underline">
                    <article class="border-l-2 border-neutral-700 pl-4 py-1 group-hover:border-white transition-colors">
                      <div class="flex flex-wrap items-center gap-2 mb-1 text-[11px] font-mono text-neutral-400">
                        <time datetime={lesson.data.date.toISOString()}>{dateLabel}</time>
                        <span>·</span>
                        <span>{lesson.data.session}</span>
                        <span>·</span>
                        <span class="uppercase tracking-wider">{lesson.data.analogy_domain}</span>
                      </div>
                      <h3 class="text-lg font-semibold tracking-tight mb-1 group-hover:underline">
                        {lesson.data.title}
                      </h3>
                      <p class="text-neutral-400 text-sm leading-relaxed">{lesson.data.excerpt}</p>
                    </article>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </div>

  </section>

  <p class="text-xs font-mono text-neutral-500 mt-8 leading-relaxed">
    Public artifacts that compound force honesty. The memory rating drops if a cold test drifts. The Findings counter only goes up if a real principle was extracted. No inflation.
  </p>
</Layout>

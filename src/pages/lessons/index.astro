---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const lessons = (await getCollection('lessons', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Forge Findings" description="Business lessons distilled from Forge build sessions.">
  <header class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight mb-2">Forge Findings</h1>
    <p class="text-neutral-300">
      Business lessons distilled from build sessions. Each Finding is one transferable principle —
      what a confident audit gets wrong, why a fix can break what was working, when the source beats
      the report — anchored in a real historical case (Theranos, Bill Campbell, Three Mile Island,
      and others as the program runs).
    </p>
    <p class="text-neutral-400 text-sm mt-3 font-mono">
      Findings ship the principle behind the code. <a href="/blog" class="underline hover:text-neutral-200">Forge posts</a> ship the code itself.
    </p>
  </header>

  {lessons.length === 0 ? (
    <p class="text-neutral-400">No findings yet.</p>
  ) : (
    <div class="space-y-6">
      {lessons.map((lesson) => {
        const dateLabel = lesson.data.date.toISOString().slice(0, 10);
        return (
          <a href={`/lessons/${lesson.slug}`} class="block group">
            <article class="border-l-2 border-neutral-700 pl-5 py-1 group-hover:border-neutral-300 transition-colors">
              <div class="flex flex-wrap items-center gap-3 mb-2 text-xs font-mono text-neutral-500">
                <time datetime={lesson.data.date.toISOString()}>{dateLabel}</time>
                <span>·</span>
                <span>{lesson.data.session}</span>
                <span>·</span>
                <span class="uppercase tracking-wider">{lesson.data.analogy_domain}</span>
              </div>
              <h2 class="text-2xl font-semibold tracking-tight mb-2 group-hover:text-white transition-colors">
                {lesson.data.title}
              </h2>
              <p class="text-neutral-400 text-base leading-relaxed">{lesson.data.excerpt}</p>
            </article>
          </a>
        );
      })}
    </div>
  )}
</Layout>

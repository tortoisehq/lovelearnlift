---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);
  return lessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }));
}

interface Props {
  lesson: CollectionEntry<'lessons'>;
}

const { lesson } = Astro.props;
const { Content } = await lesson.render();
const dateLabel = lesson.data.date.toISOString().slice(0, 10);

// Lessons share the Forge palette — black background — since they're distilled
// from Forge sessions. If a lesson ever comes from an Encode source we can split
// the palette by `task` prefix or add a `source_category` field.
const palette: 'forge' | 'encode' = 'forge';

const dateText = palette === 'encode' ? 'text-neutral-600' : 'text-neutral-400';
const tagText = palette === 'encode' ? 'text-neutral-500' : 'text-neutral-500';
const proseText = palette === 'encode' ? 'text-neutral-800' : 'text-neutral-200';
const metaText = palette === 'encode' ? 'text-neutral-500' : 'text-neutral-400';
---

<Layout title={lesson.data.title} description={lesson.data.excerpt} palette={palette}>
  <article>
    <header class="mb-10">
      <div class={`flex flex-wrap items-center gap-3 mb-4 text-sm font-sans ${dateText}`}>
        <time datetime={lesson.data.date.toISOString()}>{dateLabel}</time>
        <span class="px-2 py-0.5 rounded-sm border border-current text-xs uppercase tracking-wider">Forge Finding</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 leading-[1.1]">{lesson.data.title}</h1>
      <p class={`text-sm font-mono ${metaText}`}>
        From session <span class="text-current">{lesson.data.session}</span>
        {lesson.data.task && <> · task <span class="text-current">{lesson.data.task}</span></>}
        · pillar <span class="text-current">{lesson.data.pillar}</span>
        · analogy <span class="text-current">{lesson.data.analogy_domain}</span>
      </p>
      {lesson.data.tags.length > 0 && (
        <ul class={`flex flex-wrap gap-3 mt-3 text-xs font-mono uppercase tracking-wider ${tagText}`}>
          {lesson.data.tags.map((t) => <li>#{t}</li>)}
        </ul>
      )}
    </header>

    <div class={`prose-content space-y-5 text-lg leading-relaxed ${proseText}`}>
      <Content />
    </div>
  </article>
</Layout>

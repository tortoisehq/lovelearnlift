---
import Layout from '../layouts/Layout.astro';
// Admin draft page — calls POST /api/draft (the endpoint Miles built + shipped E38).
// Static Astro page; all the real work happens client-side via fetch.
---

<Layout title="Admin — Draft">
  <main class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-2xl font-bold mb-4">Session → Draft</h1>

    <!--
      [1] FORM — a textarea for raw session text, a button to submit.
          No real <form> submit (that reloads the page) — the button's click
          is handled entirely in the <script> below via fetch.
    -->
    <textarea id="sessionText" rows="8" class="w-full border p-2" placeholder="Paste session text..."></textarea>
    <button id="draftBtn" class="mt-3 px-4 py-2 bg-black text-white">Draft it</button>

    <!-- [2] OUTPUT — where the returned draft (or an error) gets shown. -->
    <pre id="output" class="mt-6 whitespace-pre-wrap"></pre>
  </main>

  <script>
    // [3] CLICK HANDLER — reads the textarea, POSTs to /api/draft, shows the result.
    // E38 note: finished by Claude at Miles's explicit override — logged in state.json.
    const sessionText = document.getElementById("sessionText");
    const draftBtn = document.getElementById("draftBtn");
    const output = document.getElementById("output");

    draftBtn.addEventListener("click", async () => {
      const key = sessionStorage.getItem("adminKey") || prompt("Admin key:");
      if (!key) return;
      sessionStorage.setItem("adminKey", key);

      output.textContent = "Drafting...";
      draftBtn.disabled = true;

      try {
        const res = await fetch("/api/draft", {
          method: "POST",
          headers: {
            "content-type": "application/json",
            "x-admin-key": key,
          },
          body: JSON.stringify({ sessionText: sessionText.value }),
        });
        const data = await res.json();

        if (res.status === 401) {
          sessionStorage.removeItem("adminKey");
        }
        output.textContent = data.draft || data.error || "Unknown error";
      } catch (err) {
        output.textContent = "Request failed: " + err.message;
      } finally {
        draftBtn.disabled = false;
      }
    });
  </script>
</Layout>

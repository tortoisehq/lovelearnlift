---
import Layout from '../../../layouts/Layout.astro';
import memoryLessons from '../../../data/memory-lessons.json';

type MemoryLesson = {
  lessonNumber: number;
  of: number;
  title: string;
  oneLiner: string;
  block: string;
  locus: string;
  encodedDate: string;
  encodedSession: string;
  rating: number;
  status: string;
  whyItWorks: string;
};

export async function getStaticPaths() {
  const lessons = (await import('../../../data/memory-lessons.json')).default as MemoryLesson[];
  return lessons.map((lesson) => ({
    params: { lessonNumber: String(lesson.lessonNumber) },
    props: { lesson },
  }));
}

interface Props {
  lesson: MemoryLesson;
}

const { lesson } = Astro.props;
const stars = '★'.repeat(lesson.rating) + '☆'.repeat(5 - lesson.rating);

// Build prev/next links from the full sorted list (oldest → newest navigation feels chronological).
const all = (memoryLessons as MemoryLesson[]).slice().sort((a, b) => a.lessonNumber - b.lessonNumber);
const idx = all.findIndex((l) => l.lessonNumber === lesson.lessonNumber);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
---

<Layout title={`Lesson ${lesson.lessonNumber} — ${lesson.title}`} description={lesson.oneLiner} palette="encode">
  <article>
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-4 text-sm font-sans text-neutral-600">
        <span class="font-mono">Lesson {lesson.lessonNumber} / {lesson.of}</span>
        <span class="px-2 py-0.5 rounded-sm border border-current text-xs uppercase tracking-wider">Memory Lesson</span>
        <span class="font-mono">{stars}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 leading-[1.1]">{lesson.title}</h1>
      <p class="text-lg text-black font-medium leading-relaxed mb-6">{lesson.oneLiner}</p>

      <dl class="grid grid-cols-[120px_1fr] gap-y-2 text-sm font-mono mb-2 border-t border-neutral-200 pt-5">
        <dt class="text-neutral-500">Block</dt><dd class="text-neutral-800">{lesson.block}</dd>
        <dt class="text-neutral-500">Locus</dt><dd class="text-neutral-800">{lesson.locus}</dd>
        <dt class="text-neutral-500">Encoded</dt><dd class="text-neutral-800">{lesson.encodedDate} · Session {lesson.encodedSession}</dd>
        <dt class="text-neutral-500">Rating</dt><dd class="text-neutral-800">{stars} ({lesson.rating}/5)</dd>
        <dt class="text-neutral-500">Status</dt><dd class="text-neutral-800">{lesson.status}</dd>
      </dl>
    </header>

    <section class="border-t border-neutral-200 pt-6 mb-12">
      <h2 class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">// Why it works</h2>
      <p class="text-neutral-800 leading-relaxed text-base">{lesson.whyItWorks}</p>
    </section>

    <nav class="flex items-center justify-between border-t border-neutral-200 pt-6 text-sm">
      <div>
        {prev ? (
          <a href={`/encode/memory/${prev.lessonNumber}`} class="text-neutral-700 hover:text-black no-underline">
            <span class="block text-[11px] font-mono uppercase tracking-wider text-neutral-500 mb-1">← Lesson {prev.lessonNumber}</span>
            <span class="font-semibold">{prev.title}</span>
          </a>
        ) : <span class="text-neutral-400 text-[11px] font-mono uppercase tracking-wider">— start of curriculum —</span>}
      </div>
      <div class="text-right">
        {next ? (
          <a href={`/encode/memory/${next.lessonNumber}`} class="text-neutral-700 hover:text-black no-underline">
            <span class="block text-[11px] font-mono uppercase tracking-wider text-neutral-500 mb-1">Lesson {next.lessonNumber} →</span>
            <span class="font-semibold">{next.title}</span>
          </a>
        ) : <span class="text-neutral-400 text-[11px] font-mono uppercase tracking-wider">— most recent encoded —</span>}
      </div>
    </nav>

    <p class="text-xs font-mono text-neutral-500 mt-10 leading-relaxed">
      <a href="/findings" class="underline hover:text-black">← All findings</a> · <a href="/encode" class="underline hover:text-black">Encode home</a>
    </p>
  </article>
</Layout>

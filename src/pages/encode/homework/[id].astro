---
import Layout from '../../../layouts/Layout.astro';
import Quiz from '../../../components/Quiz.astro';
import homework from '../../../data/homework.json';

type Question = {
  id: string;
  type?: 'mcq' | 'written' | 'truefalse' | 'fillblank' | 'multi' | 'order';
  concept: string;
  prompt: string;
  options?: string[];
  answer?: number | string | boolean;
  answers?: number[];
  items?: string[];
  accept?: string[];
  keywords?: string[];
  explanation: string;
  hint?: string;
  trap?: boolean;
};
type Quiz = { id: string; title: string; session: string; course: string; excerpt: string; passPct: number; questions: Question[] };

export async function getStaticPaths() {
  return (homework as Quiz[]).map((quiz) => ({ params: { id: quiz.id }, props: { quiz } }));
}

const { quiz } = Astro.props as { quiz: Quiz };
---

<Layout title={`${quiz.title} — Homework`} description={quiz.excerpt} palette="encode">
  <header class="mb-8">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">
      <a href="/encode" class="hover:text-white">// Encode</a> /
      <a href="/encode/homework" class="hover:text-white">Homework</a>
    </p>
    <p class="text-sm font-mono text-neutral-500">{quiz.course}</p>
  </header>

  <Quiz quiz={quiz} />

  <p class="mt-6 text-xs font-mono text-neutral-400">
    Scores are saved in this browser only — no account, no tracking. Clear your site data and they reset.
  </p>
  <p class="mt-2 text-xs font-mono">
    <a href="/encode/homework" class="underline hover:text-white">← All homework</a>
  </p>
</Layout>

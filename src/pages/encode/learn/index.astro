---
import Layout from '../../../layouts/Layout.astro';
// ARCHIVED E38 — quiz-course apparatus (module JSON grouping + localStorage
// mastery tracking + self-scoring quiz flow) pulled off this page per E35's
// own rule: "site quizzes are optional reinforcement, NOT a gate" — and per
// E38: rebrand Learn from course-and-quiz to project-and-build. The module
// JSON files (src/data/learn/*.json) and Quiz.astro component are untouched
// on disk — nothing deleted, just unlinked. Prior version restorable from
// git history (this file, pre-E38).

type Project = {
  id: string; title: string; learns: string; domain: string;
  status: 'shipped' | 'building' | 'planned';
};

const projects: Project[] = [
  { id: 'P1', title: 'Single API call, wired into a real workflow', learns: 'Claude Platform M1.1–M1.3 — platform, messages.create, model choice',
    domain: 'Session-notes → blog-draft tool. Built, shipped, live-tested, then pulled back to a local-only script.', status: 'shipped' },
  { id: 'P2', title: 'The agent starts taking actions', learns: 'M2.1 agent loop · M2.2 tool use',
    domain: 'A small lookup-and-answer agent.', status: 'building' },
  { id: 'P3', title: 'Thinking + keeping context straight', learns: 'M2.3 thinking · M3.1 built-in tools · M3.4 context management',
    domain: 'A different vertical than P2, on purpose — sample widely.', status: 'planned' },
  { id: 'P4', title: 'Real data + a reusable skill', learns: 'M3.2 skills · M3.3 MCP',
    domain: 'Connect to a real system worth caring about.', status: 'planned' },
  { id: 'P5', title: 'It runs itself', learns: 'M4.1 managed agents · M4.2 build your first one',
    domain: 'Promote whichever earlier project felt most alive.', status: 'planned' },
  { id: 'P6', title: 'Capstone — built with Claude Code, and the lane decision', learns: 'M5.1 building with Claude Code',
    domain: 'Review the signal from P1–P5. Pick the lane from evidence.', status: 'planned' },
];

const chip = (s: Project['status']) => s === 'shipped'
  ? { label: 'Shipped', cls: 'border-emerald-500 text-emerald-600' }
  : s === 'building'
  ? { label: 'Now building', cls: 'border-amber-500 text-amber-600' }
  : { label: 'Planned', cls: 'border-neutral-300 text-neutral-500' };
---

<Layout title="Encode Learn" description="Learning Claude by building six real, varied projects — one at a time, in public — then picking a lane from the evidence." palette="masterclass">
  <header class="mb-10">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">
      <a href="/encode" class="hover:text-black">// Encode</a> / Learn
    </p>
    <h1 class="text-4xl font-bold tracking-tight mb-3">Learn</h1>
    <p class="text-lg text-neutral-700 max-w-xl leading-relaxed">
      Learning Claude by building. Six real, varied projects — one at a time, in public — each one earning
      the next concept as the build needs it. No typecasting: the lane gets picked at the end, from evidence,
      not guessed up front.
    </p>
  </header>

  <ol class="space-y-px bg-neutral-200 border border-neutral-200">
    {projects.map((p) => {
      const c = chip(p.status);
      return (
        <li class="bg-white p-5">
          <div class="flex items-baseline justify-between gap-3 mb-1 flex-wrap">
            <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500">{p.id} · {p.learns}</span>
            <span class={`text-[10px] font-mono px-2 py-0.5 border whitespace-nowrap ${c.cls}`}>{c.label}</span>
          </div>
          <h3 class="text-xl font-semibold tracking-tight">{p.title}</h3>
          <p class="text-sm text-neutral-600 leading-relaxed mt-1">{p.domain}</p>
        </li>
      );
    })}
  </ol>

  <p class="mt-6 text-xs font-mono text-neutral-500">
    Every project ships a public case study before the next one opens. Signal — what came easy, what got
    traction — gets logged and feeds the lane decision after P5.
  </p>
</Layout>

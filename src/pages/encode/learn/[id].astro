---
// ARCHIVED E38 — individual module quiz pages retired along with the rest of
// the Learn quiz apparatus (see src/pages/encode/learn/index.astro). getStaticPaths
// is kept as-is so every old module URL still resolves (no dead links out in the
// wild) — it just redirects to the new project-building Learn hub instead of
// rendering a quiz. Full prior version (Quiz component, loop/sections render,
// prev/next nav) is in git history on this path, pre-E38.

export async function getStaticPaths() {
  const mods = import.meta.glob('../../../data/learn/*.json', { eager: true });
  const all = Object.values(mods).map((m: any) => m.default ?? m);
  return all.map((data: any) => ({ params: { id: data.id } }));
}

return Astro.redirect('/encode/learn', 301);
---
